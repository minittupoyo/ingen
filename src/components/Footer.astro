---
import { Icon } from "astro-icon/components";
---

<footer class="mt-20 border-t border-zinc-200 bg-zinc-50 py-12">
    <div class="container mx-auto max-w-7xl px-6">
        <div class="flex flex-col items-center justify-between space-y-6 md:flex-row md:space-y-0">
            <div class="flex flex-col items-center md:items-start">
                <a href="/" class="text-xl font-bold">
                    minittu<span class="text-orange-500">.</span>
                </a>
                <p class="mt-2 text-sm text-zinc-500">
                    &copy; {new Date().getFullYear()} みにっつ. All rights reserved.
                </p>
            </div>

            <div class="flex flex-row items-center space-x-6">
                <a
                    href="https://github.com/minittupoyo"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-zinc-500 transition-colors hover:text-zinc-900"
                    aria-label="GitHub"
                >
                    <Icon name="tabler:brand-github" class="h-6 w-6" />
                </a>
            </div>
        </div>
    </div>
</footer>
