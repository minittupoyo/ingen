---
import type { CollectionEntry } from "astro:content";

interface Props {
    post: CollectionEntry<"blog">;
}

const { post } = Astro.props;

const bgColors = [
    "bg-orange-50",
    "bg-emerald-50",
    "bg-pink-50",
    "bg-sky-50",
    "bg-violet-50",
    "bg-amber-50",
    "bg-rose-50",
    "bg-cyan-50",
];

const randomBg = bgColors[Math.floor(Math.random() * bgColors.length)];
---

<a
    href={`/blog/${post.id}`}
    class="group flex flex-col overflow-hidden rounded-lg border border-zinc-200 shadow shadow-zinc-200 transition duration-300 hover:-translate-y-1 hover:shadow-xl"
>
    <div
        class={`flex aspect-video w-full items-center justify-center border-b border-zinc-200 ${randomBg}`}
    >
        <p class="text-6xl">{post.data.emoji}</p>
    </div>
    <div class="flex flex-col space-y-1 p-4">
        <p class="text-sm text-zinc-500">
            {
                post.data.date.toLocaleDateString("ja-jp", {
                    year: "numeric",
                    month: "2-digit",
                    day: "2-digit",
                })
            }
        </p>
        <p class="line-clamp-2 text-xl font-bold">{post.data.title}</p>
        <p class="line-clamp-2 text-base text-zinc-700">
            {post.data.description}
        </p>
    </div>
</a>
